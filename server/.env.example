PORT=4000
HOST=0.0.0.0
# ब्राउज़र ओरिजिन (कॉमा से अलग) — Socket.IO + CORS
CLIENT_ORIGIN=http://localhost:5173
DATABASE_URL=file:./dev.db
# रिवर्स प्रॉक्सी (nginx/fly) के पीछे सही IP के लिए
TRUST_PROXY=0
# ऑप्शनल — JWT सॉकेट ऑथ के लिए (अभी कोड में हुक है; वेरीफाई लगाना हो तो jsonwebtoken जोड़ें)
JWT_SECRET=
